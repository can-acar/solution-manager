          "group": "7_dependency@11"
        },
        {
          "command": "solutionManager.dependencyRemoveReference",
          "when": "view == solutionManager.solutionView && (viewItem == dependencyItem.assemblies || viewItem == dependencyItem.frameworks || viewItem == dependencyItem.analyzers)",
          "group": "7_dependency@12"
        },
