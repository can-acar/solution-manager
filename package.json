          "command": "solutionManager.dependencyRemoveProjectReference",
          "when": "view == solutionManager.solutionView && viewItem == dependencyItem.projects",
          "group": "7_dependency@13"
        },
        {
          "command": "solutionManager.dependencyGroupDetails",
          "when": "view == solutionManager.solutionView && (viewItem == dependencyGroup.assemblies || viewItem == dependencyGroup.projects || viewItem == dependencyGroup.analyzers || viewItem == dependencyGroup.packages || viewItem == dependencyGroup.transitivePackages || viewItem == dependencyGroup.frameworks || viewItem == dependencyGroup.sourceGenerators || viewItem == dependencyGroup.packageDependency || viewItem == dependencyGroup.compileAssets || viewItem == dependencyGroup.runtimeAssets)",
          "group": "7_dependency@0"
        },
        {
          "command": "solutionManager.addAssemblyReference",
          "when": "view == solutionManager.solutionView && viewItem == dependencyGroup.assemblies",
          "group": "7_dependency@1"
        },
        {
          "command": "solutionManager.addFrameworkReference",
          "when": "view == solutionManager.solutionView && viewItem == dependencyGroup.frameworks",
          "group": "7_dependency@1"
        },
        {
          "command": "solutionManager.addAnalyzerReference",
          "when": "view == solutionManager.solutionView && viewItem == dependencyGroup.analyzers",
          "group": "7_dependency@1"
