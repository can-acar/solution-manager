    "menus": {
      "view/title": [
        {
          "command": "solutionManager.refresh",
          "when": "view == solutionManager.solutionView",
          "group": "navigation@1"
        },
        {
          "command": "solutionManager.addProject",
          "when": "view == solutionManager.solutionView",
          "group": "navigation@2"
        }
      ],
      "view/item/context": [
        {
          "submenu": "solutionManager.project.add",
          "when": "view == solutionManager.solutionView && (viewItem == projectLoaded || viewItem == projectTestLoaded)",
          "group": "1_add@1"
        },
        {
          "command": "solutionManager.manageNuGetPackages",
          "when": "view == solutionManager.solutionView && (viewItem == projectLoaded || viewItem == projectTestLoaded)",
          "group": "1_add@2"
        },
        {
          "command": "solutionManager.unloadProject",
          "when": "view == solutionManager.solutionView && (viewItem == projectLoaded || viewItem == projectTestLoaded)",
          "group": "1_add@3"
        },
        {
          "command": "solutionManager.reloadProject",
          "when": "view == solutionManager.solutionView && viewItem == projectUnloaded",
          "group": "1_add@4"
        },
        {
          "submenu": "solutionManager.project.ef",
          "when": "view == solutionManager.solutionView && (viewItem == projectLoaded || viewItem == projectTestLoaded)",
          "group": "2_ef@1"
        },
        {
          "command": "solutionManager.buildSelectedProjects",
          "when": "view == solutionManager.solutionView && (viewItem == projectLoaded || viewItem == projectTestLoaded)",
          "group": "3_build@1"
        },
        {
          "command": "solutionManager.runUnitTest",
          "when": "view == solutionManager.solutionView && viewItem == projectTestLoaded",
          "group": "3_build@2"
        },
        {
          "command": "solutionManager.publishProject",
          "when": "view == solutionManager.solutionView && (viewItem == projectLoaded || viewItem == projectTestLoaded)",
          "group": "3_build@3"
        },
        {
          "submenu": "solutionManager.project.advancedBuild",
          "when": "view == solutionManager.solutionView && (viewItem == projectLoaded || viewItem == projectTestLoaded)",
          "group": "3_build@4"
        },
        {
          "submenu": "solutionManager.project.git",
          "when": "view == solutionManager.solutionView && (viewItem == projectLoaded || viewItem == projectTestLoaded || viewItem == projectUnloaded)",
          "group": "4_tools@1"
        },
        {
          "submenu": "solutionManager.project.copy",
          "when": "view == solutionManager.solutionView && (viewItem == projectLoaded || viewItem == projectTestLoaded || viewItem == projectUnloaded)",
          "group": "5_open@1"
        },
        {
          "submenu": "solutionManager.project.openIn",
          "when": "view == solutionManager.solutionView && (viewItem == projectLoaded || viewItem == projectTestLoaded || viewItem == projectUnloaded)",
          "group": "5_open@2"
        },
        {
          "command": "solutionManager.showProperties",
          "when": "view == solutionManager.solutionView && (viewItem == projectLoaded || viewItem == projectTestLoaded || viewItem == projectUnloaded)",
          "group": "6_properties@1"
        },
        {
          "command": "solutionManager.openTreeItem",
          "when": "view == solutionManager.solutionView && (viewItem == solution || viewItem == file)",
          "group": "inline@1"
        },
        {
          "command": "solutionManager.dependencyGroupDetails",
          "when": "view == solutionManager.solutionView && viewItem == dependencies",
          "group": "7_dependency@0"
        },
        {
          "command": "solutionManager.manageNuGetPackages",
          "when": "view == solutionManager.solutionView && viewItem == dependencies",
          "group": "7_dependency@1"
        },
        {
          "command": "solutionManager.restoreProject",
          "when": "view == solutionManager.solutionView && viewItem == dependencies",
          "group": "7_dependency@2"
        },
        {
          "command": "solutionManager.dependencyListPackages",
          "when": "view == solutionManager.solutionView && viewItem == dependencies",
          "group": "7_dependency@3"
        },
        {
          "command": "solutionManager.showProperties",
          "when": "view == solutionManager.solutionView && viewItem == dependencies",
          "group": "7_dependency@4"
        },
        {
          "command": "solutionManager.dependencyGroupDetails",
          "when": "view == solutionManager.solutionView && viewItem == dependencyImports",
          "group": "7_dependency@0"
        },
        {
          "command": "solutionManager.dependencyFrameworkDetails",
          "when": "view == solutionManager.solutionView && viewItem == dependencyFramework",
          "group": "7_dependency@1"
        },
        {
          "command": "solutionManager.dependencyBuildFramework",
          "when": "view == solutionManager.solutionView && viewItem == dependencyFramework",
          "group": "7_dependency@2"
        },
        {
          "command": "solutionManager.dependencyTestFramework",
          "when": "view == solutionManager.solutionView && viewItem == dependencyFramework",
          "group": "7_dependency@3"
        },
        {
          "command": "solutionManager.dependencyCopyFramework",
          "when": "view == solutionManager.solutionView && viewItem == dependencyFramework",
          "group": "7_dependency@4"
        },
        {
          "command": "solutionManager.dependencyPackageDetails",
          "when": "view == solutionManager.solutionView && (viewItem == dependencyPackage.direct || viewItem == dependencyPackage.transitive || viewItem == dependencyItem.packages || viewItem == dependencyItem.packageDependency)",
          "group": "7_dependency@1"
        },
        {
          "command": "solutionManager.dependencyOpenNuGet",
          "when": "view == solutionManager.solutionView && (viewItem == dependencyPackage.direct || viewItem == dependencyPackage.transitive || viewItem == dependencyItem.packages || viewItem == dependencyItem.packageDependency)",
          "group": "7_dependency@2"
        },
        {
          "command": "solutionManager.dependencyOpenPackageFolder",
          "when": "view == solutionManager.solutionView && (viewItem == dependencyPackage.direct || viewItem == dependencyPackage.transitive || viewItem == dependencyItem.packages || viewItem == dependencyItem.packageDependency)",
          "group": "7_dependency@3"
        },
        {
          "submenu": "solutionManager.dependency.copy",
          "when": "view == solutionManager.solutionView && (viewItem == dependencyPackage.direct || viewItem == dependencyPackage.transitive || viewItem == dependencyItem.packages || viewItem == dependencyItem.packageDependency)",
          "group": "7_dependency@4"
        },
        {
          "command": "solutionManager.dependencyUpdatePackage",
          "when": "view == solutionManager.solutionView && (viewItem == dependencyPackage.direct || viewItem == dependencyItem.packages)",
          "group": "7_dependency@5"
        },
        {
          "command": "solutionManager.dependencyRemovePackage",
          "when": "view == solutionManager.solutionView && (viewItem == dependencyPackage.direct || viewItem == dependencyItem.packages)",
          "group": "7_dependency@6"
        },
        {
          "command": "solutionManager.dependencyListPackages",
          "when": "view == solutionManager.solutionView && (viewItem == dependencyPackage.direct || viewItem == dependencyPackage.transitive || viewItem == dependencyItem.packages || viewItem == dependencyItem.packageDependency)",
          "group": "7_dependency@7"
        },
        {
          "command": "solutionManager.dependencyReferenceDetails",
          "when": "view == solutionManager.solutionView && (viewItem == dependencyItem.import || viewItem == dependencyItem.assemblies || viewItem == dependencyItem.projects || viewItem == dependencyItem.analyzers || viewItem == dependencyItem.frameworks || viewItem == dependencyItem.sourceGenerators || viewItem == dependencyItem.compileAssets || viewItem == dependencyItem.runtimeAssets)",
          "group": "7_dependency@8"
        },
        {
          "command": "solutionManager.dependencyOpenReference",
          "when": "view == solutionManager.solutionView && (viewItem == dependencyItem.import || viewItem == dependencyItem.assemblies || viewItem == dependencyItem.projects || viewItem == dependencyItem.analyzers || viewItem == dependencyItem.sourceGenerators || viewItem == dependencyItem.compileAssets || viewItem == dependencyItem.runtimeAssets)",
          "group": "7_dependency@9"
        },
        {
          "command": "solutionManager.dependencyOpenReferenceFolder",
