    "onCommand:solutionManager.restoreProject",
    "onCommand:solutionManager.cleanProject",
    "onCommand:solutionManager.rebuildProject",
    "onCommand:solutionManager.packProject",
    "onCommand:solutionManager.gitStatusProject",
    "onCommand:solutionManager.gitDiffProject",
    "onCommand:solutionManager.gitLogProject",
    "onCommand:solutionManager.copyFullPath",
    "onCommand:solutionManager.copyRelativePath",
    "onCommand:solutionManager.copyProjectReferenceXml",
    "onCommand:solutionManager.copyProjectName",
    "onCommand:solutionManager.openInEditor",
    "onCommand:solutionManager.openInExplorer",
    "onCommand:solutionManager.openInTerminal",
    "onCommand:solutionManager.showProperties",
    "onCommand:solutionManager.dependencyPackageDetails",
    "onCommand:solutionManager.dependencyOpenNuGet",
    "onCommand:solutionManager.dependencyOpenPackageFolder",
    "onCommand:solutionManager.dependencyCopyPackageId",
    "onCommand:solutionManager.dependencyCopyPackageFolder",
    "onCommand:solutionManager.dependencyCopyPackageReference",
    "onCommand:solutionManager.dependencyCopyPackageSourceMapping",
    "onCommand:solutionManager.dependencyGroupDetails",
    "onCommand:solutionManager.dependencyUpdatePackage",
    "onCommand:solutionManager.dependencyRemovePackage",
    "onCommand:solutionManager.dependencyListPackages",
    "onCommand:solutionManager.dependencyReferenceDetails",
    "onCommand:solutionManager.dependencyOpenReference",
    "onCommand:solutionManager.dependencyOpenReferenceFolder",
    "onCommand:solutionManager.dependencyCopyReferenceName",
    "onCommand:solutionManager.dependencyCopyReferencePath",
    "onCommand:solutionManager.dependencyCopyReferenceXml",
    "onCommand:solutionManager.dependencyRemoveReference",
    "onCommand:solutionManager.dependencyRemoveProjectReference",
    "onCommand:solutionManager.dependencyFrameworkDetails",
    "onCommand:solutionManager.dependencyBuildFramework",
    "onCommand:solutionManager.dependencyTestFramework",
    "onCommand:solutionManager.dependencyCopyFramework"
